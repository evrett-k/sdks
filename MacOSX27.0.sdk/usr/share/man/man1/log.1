.Op Fl -fatal-warnings
.Op Fl -mutate
.Op Fl -predicate Ar predicate
.Op Fl -skip-uuid-purge
.\" TODO: these are not documented since they don't work yet. rdar://137683254
.\".Op Fl -last Ar num Ns Oo Ar s|m|h|d Oc | Ar boot
.\".Op Fl -start Ar date/time
.\".Op Fl -end Ar date/time
.Pp
.Nm
.Cm show
.Op Fl -archive Ar archive | Fl -file Ar file
.Op Fl -predicate Ar filter
.Op Fl -highlight-predicate Ar filter
.Op Fl -process Ar pid | process
.Op Fl -source
.Op Fl -style Ar default | compact | json | ndjson | syslog
.Op Fl -color Ar auto | always | none
.Op Fl -directory Ar directory
