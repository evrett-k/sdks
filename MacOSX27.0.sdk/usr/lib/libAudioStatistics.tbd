--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, arm64e-macos ]
install-name:    '/usr/lib/libAudioStatistics.dylib'
swift-abi-version: 7
exports:
  - targets:         [ x86_64-macos, arm64e-macos ]
    symbols:         [ _AudioAnalyticsRetainMessage, _CAReportingApplicationName, 
                       _CAReportingAriadneInputFilePath, _CAReportingAriadneOutputFileDirectory, 
                       _CAReportingAriadneOutputFileName, _CAReportingAriadnePlistFilePath, 
                       _CAReportingAriadnePlistFilePaths, _CAReportingClientCopyConfiguration, 
                       _CAReportingClientCreateReporterID, _CAReportingClientCreateReporterIDFromSessionID, 
                       _CAReportingClientDestroyReporterID, _CAReportingClientGetAudioServiceType, 
                       _CAReportingClientRequestMessage, _CAReportingClientSendMessage, 
                       _CAReportingClientSendSingleMessage, _CAReportingClientSetAudioServiceType, 
                       _CAReportingClientSetConfiguration, _CAReportingClientStartReporter, 
                       _CAReportingClientStopReporter, _CAReportingDelayPerfEndSnapShot, 
                       _CAReportingPerfAggregateMetrics, _CAReportingPerfProcesses, 
                       _CAReportingTestName, _CAReportingTraceType, _CAReportingTraceTypeArtrace, 
                       _CAReportingTraceTypeArtraceProfile, _CAReportingTraceTypeKtrace, 
                       _CAReportingUtilityGenerateServiceNameFromServiceType, _CAReportingUtilityGenerateServiceTypeFromServiceName, 
                       _CreateSharedCAReportingClient ]
    objc-classes:    [ CAReporter, CATestReporter ]
...
