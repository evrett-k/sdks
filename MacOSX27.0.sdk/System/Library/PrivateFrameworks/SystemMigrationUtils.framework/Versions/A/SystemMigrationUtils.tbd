--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, arm64e-macos ]
install-name:    '/System/Library/PrivateFrameworks/SystemMigrationUtils.framework/Versions/A/SystemMigrationUtils'
exports:
  - targets:         [ x86_64-macos, arm64e-macos ]
    symbols:         [ _SMUDTFirmlinkDestinationKey, _SMUDTFirmlinkSourceKey, _SMUDTTemplateReceiptIdentifier, 
                       _SMUDataTemplateErrorDomain, _SystemMigrationUtilsVersionNumber, 
                       _SystemMigrationUtilsVersionString, _getPairedVolumeWithRole, 
                       _isCaseSensitive ]
    objc-classes:    [ SMConnectionFamilyIcons, SMLogging, SMPathSizer, SMSystemConfiguration, 
                       SMSystem_FileManager_DiskBased, SMSystem_FileManager_ROSV, 
                       SMSystem_FileManager_Traditional, SMSystem_FileManager_macOS, 
                       SMTask, SMToolBox, SMUDataTemplateCopier, SMUDataTemplateUtilities, 
                       SMUVersion, SMUtilities ]
...
