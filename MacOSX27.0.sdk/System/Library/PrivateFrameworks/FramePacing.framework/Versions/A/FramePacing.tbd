--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, x86_64-maccatalyst, arm64e-macos, arm64e-maccatalyst ]
install-name:    '/System/Library/PrivateFrameworks/FramePacing.framework/Versions/A/FramePacing'
exports:
  - targets:         [ x86_64-macos, x86_64-maccatalyst, arm64e-macos, arm64e-maccatalyst ]
    symbols:         [ _FPCAMetalLayerAllocated, _FPCommandBufferCommitted, _FPCommandBufferCompleted, 
                       _FPCommandBufferCreated, _FPCommandBufferScheduled, _FPDrawableLifetimeMarkClientDidPresent, 
                       _FPDrawableLifetimeMarkComposited, _FPDrawableLifetimeMarkFinished, 
                       _FPDrawableLifetimeMarkStarted, _FPGPTkDeviceCreated, _FPMTL4CommandBufferBegin, 
                       _FPMTL4CommandBufferCommitted, _FPMTL4CommandBufferCompleted, 
                       _FPMTL4CommandBufferCreated, _FPMTL4CommandBufferDealloc, 
                       _FPMTL4CommandBufferEnd, _FPMTLCompilerFunctionCompiled, _FPMTLCompilerPipelineStateCreated, 
                       _FPMTLDeviceCreatedWithFramePacingVersion, _FPMachAbsoluteToRescaledMachContinuous, 
                       _FPMetalFXFrameInterpolatorEncoded, _FPMetalFXReportInterpolatorPerformance, 
                       _FPMetalFXReportScalingPerformance, _FPMetalFXScalingEncoded, 
                       _FPMetalLayerMarkDealloc, _FPMetalLayerMarkSetName, _FPMetalLayerMarkSetPixelFormat, 
                       _FPMetalLayerMarkSetSize, _FPRUsageTimestampToTimeInterval, 
                       _FPRescaledMachTimestampDeltaToTimeInterval, _FPScaleMachTimestamp, 
                       _FPTimeIntervalToMachContinuousRescaled, _FP_mach_continuous_time_rescaled, 
                       __FPCheckEnvironmentVariablesAndDefaultsForConfiguration, 
                       __FPConfigurationCheckingQueue, __FPConfigurationSetAggregationInterval, 
                       __FPConfigurationSetPerDrawableSignpostingEnabled, __FPConfigurationSetSeparatePerDrawableSignpostCategoryEnabled, 
                       __FPConfigurationSettingQueue, __FPGetCurrentAggregationIntervalSeconds, 
                       __FPGetCurrentPerDrawableSignpostingEnabled, __FPGetCurrentShaderCompilerStatSignpostsEnabled, 
                       __FPGetSeparatePerDrawableSignpostCategoryEnabled, __FPGlobalLayerStateDictionary, 
                       __FPLayerStateAcquiredDrawableCount, __FPLayerStateClientPresentedInFlightDrawableCount, 
                       __FPLayerStateSyncQueue, __FPResetConfigurationToDefault, 
                       __FPSetCurrentShaderCompilerStatSignpostsEnabled, __fpCommandBufferDebugHandle, 
                       __fpConfigurationHandle, __fpDrawableLifetimeDebugHandle, 
                       __fpErrorHandle, __fpIdleDebugHandle, __fpMetalLayerDebugHandle, 
                       __fpPerDrawableHandle, __fpRusageDebugHandle, __fpStateHandle, 
                       __fpTimeDebugHandle, __shouldEmitErrorSignpost, _gFPInFlightDrawableLifetimeCount, 
                       _gFPLayerCount, _gFPNeedsReportCount, _gFPTotalFunctionMCTR, 
                       _gFPTotalProcessingTimeMCTR, _kFPAggregationIntervalSecondsDefaultsVariableName, 
                       _kFPAggregationIntervalSecondsEnvironmentVariableName, _kFPDefaultAggregationIntervalSec, 
                       _kFPDefaultPerFrameSignpostingIsEnabled, _kFPDefaultSeparatePerDrawableHandle, 
                       _kFPEnableDrawableSignpostingDefaultsVariableName, _kFPEnableDrawableSignpostingDefaultsVariableName_MetalPerformanceOverview, 
                       _kFPEnableDrawableSignpostingEnvironmentVariableName, _kFPEnableDrawableSignpostingEnvironmentVariableName_MetalPerformanceOverview, 
                       _kFPEnableSeparatePerDrawableCategoryEnvironmentVariableName, 
                       _kFPEnableSeparatePerDrawableCategoryVariableName, _kFPEnableShaderCompilerStatSignpostsDefaultsVariableName, 
                       _kFPEnableShaderCompilerStatSignpostsEnvironmentVariableName, 
                       _kFPMaxAggregationIntervalSec, _kFPMinAggregationIntervalSec, 
                       _kFPNoValueTimeInterval ]
    objc-classes:    [ FPCAMetalLayerAggregatedStats, FPCAMetalLayerAggregatedStatsGPTK, 
                       FPCAMetalLayerAggregatedStatsShaderCompiler, FPCAMetalLayerState, 
                       FPDurationStatistics, FPInFlightDrawableLifetime, FPMTLMetricsClientInsight, 
                       FPMTLMetricsClientInsightGroup, FPMTLMetricsClientMetricCollection, 
                       FPMTLMetricsClientMetricDescriptor, FPMTLMetricsClientMetricDescriptorGroup, 
                       FPMTLMetricsClientMetricValue, FPMTLMetricsMetricsBundleInternal, 
                       FPMTLMetricsServiceInternal, FPOnGlassCAMetalLayerDrawableInterval, 
                       _CADeveloperHUDProperties ]
...
