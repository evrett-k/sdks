--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, arm64e-macos ]
install-name:    '/System/Library/PrivateFrameworks/HID.framework/Versions/A/HID'
exports:
  - targets:         [ x86_64-macos, arm64e-macos ]
    symbols:         [ _HIDVersionNumber, _HIDVersionString, _IOHIDAnalyticsGetConsoleModeStatus, 
                       _kHIDUserDevicePropertyCreateInactiveKey ]
    objc-classes:    [ HIDEventSystemClient, HIDLibElement, HIDManager, HIDTimeSync, 
                       HIDUserDevice, HIDVirtualEventService, IOHIDDeviceClass, IOHIDIUnknown2, 
                       IOHIDObsoleteDeviceClass, IOHIDObsoleteQueueClass, IOHIDOutputTransactionClass, 
                       IOHIDPlugin, IOHIDQueueClass, IOHIDTransactionClass ]
    objc-ivars:      [ IOHIDDeviceClass._port, IOHIDDeviceClass._queue, IOHIDDeviceClass._runLoopSource, 
                       IOHIDDeviceClass._service, IOHIDIUnknown2._vtbl, IOHIDObsoleteDeviceClass._interface, 
                       IOHIDObsoleteDeviceClass._notification, IOHIDObsoleteDeviceClass._notifyPort, 
                       IOHIDObsoleteDeviceClass._removalCallback, IOHIDObsoleteDeviceClass._removalRefcon, 
                       IOHIDObsoleteDeviceClass._removalTarget, IOHIDObsoleteDeviceClass._reportCallback, 
                       IOHIDObsoleteDeviceClass._reportCallbackRefcon, IOHIDObsoleteDeviceClass._reportCallbackTarget, 
                       IOHIDObsoleteQueueClass._eventCallback, IOHIDObsoleteQueueClass._eventCallbackRefcon, 
                       IOHIDObsoleteQueueClass._eventCallbackTarget, IOHIDObsoleteQueueClass._interface, 
                       IOHIDOutputTransactionClass._outputInterface, IOHIDPlugin._plugin, 
                       IOHIDPlugin._uuid, IOHIDQueueClass._depth, IOHIDQueueClass._device, 
                       IOHIDQueueClass._lastTail, IOHIDQueueClass._machPort, IOHIDQueueClass._port, 
                       IOHIDQueueClass._queue, IOHIDQueueClass._queueLock, IOHIDQueueClass._queueMemory, 
                       IOHIDQueueClass._queueMemorySize, IOHIDQueueClass._queueSizeChanged, 
                       IOHIDQueueClass._queueToken, IOHIDQueueClass._runLoopSource, 
                       IOHIDQueueClass._usageAnalytics, IOHIDQueueClass._valueAvailableCallback, 
                       IOHIDQueueClass._valueAvailableContext, IOHIDTransactionClass._callbackLock, 
                       IOHIDTransactionClass._device, IOHIDTransactionClass._direction, 
                       IOHIDTransactionClass._elements, IOHIDTransactionClass._interface, 
                       IOHIDTransactionClass._pendingCallbacks ]
...
