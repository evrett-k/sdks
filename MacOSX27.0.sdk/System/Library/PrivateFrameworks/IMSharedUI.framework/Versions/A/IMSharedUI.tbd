                       _NSStringFromIMRectCorner, _NSStringFromIMTailShape, _NSStringFromIMTranscriptOrientation, 
                       __IMDispatchQueueBlockCompare, _ackNameForAcknowledgmentType, 
                       _kCKThinkingDotsOpacityDefault ]
