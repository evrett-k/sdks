                       _BridgeOSInstallOptionPersonalizationServerURL, _BridgeOSInstallOptionPredicateProductOriginatingCatalogURL, 
                       _BridgeOSInstallOptionShowUI, _BridgeOSInstallOptionTestModeEnabled, 
                       _BridgeOSInstallStatusKeyDownloadedBytes, _BridgeOSInstallStatusKeyEstimatedTimeRemaining, 
                       _BridgeOSInstallStatusKeyPercentComplete, _BridgeOSInstallStatusKeyTotalBytes, 
                       _BridgeOSInstallVersionNumber, _BridgeOSInstallVersionString ]
    objc-classes:    [ BridgeOSInstallController, BridgeOSInstallDownloader ]
...
