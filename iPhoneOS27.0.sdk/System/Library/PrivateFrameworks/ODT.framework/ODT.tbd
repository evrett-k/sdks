--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/ODT.framework/ODT
current-version:       26.5
compatibility-version: 26.5
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _ODT3DCompileReferenceObjects, _ODT3DConfigCreate,
                            _ODT3DConfigCreateWithDBPath,
                            _ODT3DConfigCreateWithDBPaths,
                            _ODT3DConfigCreateWithObjects,
                            _ODT3DConfigCreateWithPipelineParams,
                            _ODT3DConfigCreateWithPipelineParamsAndCompile,
                            _ODT3DConfigCreateWithReferenceObjects,
                            _ODT3DConfigRelease, _ODT3DConfigRetain,
                            _ODT3DConfigSetModelDatabasePaths,
                            _ODT3DConfigSetPipelineParameters,
                            _ODT3DConfigSetPipelinePreset,
                            _ODT3DConfigSetWarperType,
                            _ODT3DModelCatalogAssetsFetchResultCopyError,
                            _ODT3DObjectsCreate, _ODT3DObjectsCreateWithDetail,
                            _ODT3DObjectsRelease, _ODT3DObjectsRetain,
                            _ODT3DPipelineParametersCreate,
                            _ODT3DPipelineParametersGetDetectionRate,
                            _ODT3DPipelineParametersGetMaximumConcurrentObjects,
                            _ODT3DPipelineParametersGetMaximumInstancesPerClass,
                            _ODT3DPipelineParametersGetMovingTrackingRate,
                            _ODT3DPipelineParametersGetStationaryTrackingRate,
                            _ODT3DPipelineParametersRelease,
                            _ODT3DPipelineParametersRetain,
                            _ODT3DPipelineParametersSetDetectionRate,
                            _ODT3DPipelineParametersSetMaximumConcurrentObjects,
                            _ODT3DPipelineParametersSetMaximumInstancesPerClass,
                            _ODT3DPipelineParametersSetMovingTrackingRate,
                            _ODT3DPipelineParametersSetStationaryTrackingRate,
                            _ODT3DReconfigurePipelineResultCopyError,
                            _ODT3DReconfigurePipelineResultCopyInput,
                            _ODT3DReconfigureResultCopyError,
                            _ODT3DReferenceObjectCreate,
                            _ODT3DReferenceObjectCreateWithPath,
                            _ODT3DReferenceObjectRelease,
                            _ODT3DReferenceObjectRetain,
                            _ODT3DReferenceObjectSetFilePath,
                            _ODT3DReferenceObjectSetFrameRateSetting,
                            _ODT3DReferenceObjectSetSmoothing,
                            _ODT3DResultGet3DKeypoints,
                            _ODT3DResultGetBoundingBox, _ODT3DResultGetClassId,
                            _ODT3DResultGetConfidence, _ODT3DResultGetExtent,
                            _ODT3DResultGetInstanceId,
                            _ODT3DResultGetIsScaleReliable,
                            _ODT3DResultGetNumKeypoints,
                            _ODT3DResultGetNumberOfObjects,
                            _ODT3DResultGetObjectId, _ODT3DResultGetOiDone,
                            _ODT3DResultGetRetainCount, _ODT3DResultGetScale,
                            _ODT3DResultGetTimestamp,
                            _ODT3DResultGetTrackingState,
                            _ODT3DResultGetTrackingTimestamp,
                            _ODT3DResultGetTransform,
                            _ODT3DResultGetTransformToCamera,
                            _ODT3DResultGetUUID, _ODT3DResultIsTracked,
                            _ODT3DResultRelease, _ODT3DResultRetain,
                            _ODT3DSessionClearReferenceObjectsUnsafe,
                            _ODT3DSessionCreate, _ODT3DSessionFetchAssetsOTASync,
                            _ODT3DSessionGetMaximumAppleDeviceInstances,
                            _ODT3DSessionGetPipelineParameters,
                            _ODT3DSessionGetTotalReferenceObjectsConfigured,
                            _ODT3DSessionMaxAppleDevices,
                            _ODT3DSessionProcessSyncCreateResult,
                            _ODT3DSessionReconfigure,
                            _ODT3DSessionReconfigurePipeline,
                            _ODT3DSessionRelease,
                            _ODT3DSessionReleaseModelCatalogAssets,
                            _ODT3DSessionSetModelCatalogAssetsFetchResultBlock,
                            _ODT3DSessionSetReconfigurePipelineResultBlock,
                            _ODT3DSessionSetReconfigureResultBlock,
                            _ODT3DSessionSetResultBlock, _ODTCLI_Main,
                            _ODTCalibrationCreate,
                            _ODTCalibrationFFADescriptorCreate,
                            _ODTCalibrationFFADescriptorRelease,
                            _ODTCalibrationFFAViewCreate,
                            _ODTCalibrationFFAViewRelease,
                            _ODTCalibrationRelease,
                            _ODTCalibrationSetCameraParameters,
                            _ODTCalibrationSetFFACalibration,
                            _ODTComponentConfigGetDetectorConfig,
                            _ODTComponentConfigGetTrackerConfig,
                            _ODTComponentDetectorConfigGetTimeIntervals,
                            _ODTComponentDetectorConfigSetTimeInterval,
                            _ODTComponentTrackerConfigGetForceDetection,
                            _ODTComponentTrackerConfigGetMaximumTracked,
                            _ODTComponentTrackerConfigGetScaleEstimation,
                            _ODTComponentTrackerConfigGetTimeInterval,
                            _ODTComponentTrackerConfigSetForceDetection,
                            _ODTComponentTrackerConfigSetMaximumTracked,
                            _ODTComponentTrackerConfigSetScaleEstimation,
                            _ODTComponentTrackerConfigSetTimeInterval,
                            _ODTReturnFromCFError,
                            _kODTCalibrationFFARayMapperEllipsoidal,
                            _kODTCalibrationFFARayMapperFTheta,
                            _kODTCalibrationFFARayMapperPolar,
                            _kODTCalibrationFFARayMapperPolarMuLaw,
                            _kODT_DeterministicMode ]
...
