--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/CoreRoutineDiagnostics.framework/CoreRoutineDiagnostics
current-version:       1119
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _CRDMemoryFootprint, _RTBugCaptureCategoryString,
                            _RTCommonCalculateBoundingBox,
                            _RTCommonCalculateDistance,
                            _RTCommonCalculateDistanceHighPrecision,
                            _RTCommonConvertGeodeticToLocalFrame,
                            _RTCommonConvertLocalFrameToGeodetic,
                            _RTCommonGetDestinationCoordinate,
                            _RTCommonIsCoordinateValid, _RTCommonRandomDouble,
                            _RTCommonRandomFlip, _RTCommonRandomInt,
                            _RTCommonSafeLog, _RTCommonValidConfidence,
                            _kRTBugCaptureMetricKeyCaptureAttempts,
                            _kRTBugCaptureMetricKeyCategoryAttemptsBackgroundTaskHighFailureRate,
                            _kRTBugCaptureMetricKeyCategoryAttemptsBackgroundTaskSchedulingViolation,
                            _kRTBugCaptureMetricKeyCategoryAttemptsCombinedPerformanceViolation,
                            _kRTBugCaptureMetricKeyCategoryAttemptsDataIntegrityViolation,
                            _kRTBugCaptureMetricKeyCategoryAttemptsExceptionCaught,
                            _kRTBugCaptureMetricKeyCategoryAttemptsHighCPUDetected,
                            _kRTBugCaptureMetricKeyCategoryAttemptsHighLatencyDetected,
                            _kRTBugCaptureMetricKeyCategoryAttemptsIpsDetected,
                            _kRTBugCaptureMetricKeyCategoryAttemptsLOIUUIDStabilityIssueDetected,
                            _kRTBugCaptureMetricKeyCategoryAttemptsLongProcessInit,
                            _kRTBugCaptureMetricKeyCategoryAttemptsMemoryThresholdExceeded,
                            _kRTBugCaptureMetricKeyCategoryAttemptsSemaphoreHangDetected,
                            _kRTBugCaptureMetricKeyCategoryAttemptsVisitGapDetected,
                            _kRTBugCaptureMetricKeyRadarsFiled,
                            _kRTBugCaptureMetricKeySuppressedBackoff,
                            _kRTBugCaptureMetricKeySuppressedDisabled,
                            _kRTBugCaptureMetricKeySuppressedDownsampling,
                            _kRTBugCaptureMetricKeySuppressedInvalidParameters,
                            _kRTBugCaptureMetricKeySuppressedNoStorageDelegate,
                            _kRTBugCaptureMetricKeySuppressedNotInternalInstall,
                            _kRTBugCaptureMetricKeySuppressedProfileNotAllowed,
                            _kRTBugCaptureMetricKeySuppressedPromptingDisabled,
                            _kRTBugCaptureMetricKeySuppressedUserDeclined,
                            _kRTBugCaptureMetricKeySuppressedUserOptOut,
                            _kRTBugCaptureMetricKeyUserProfile,
                            _kRTBugCaptureRadarFiledMetricKeyCategory,
                            _kRTBugCaptureRadarFiledMetricKeyDayOfWeek,
                            _kRTBugCaptureRadarFiledMetricKeyDiagnosticsMask,
                            _kRTBugCaptureRadarFiledMetricKeyHour,
                            _kRTBugCaptureRadarFiledMetricKeyModule,
                            _kRTBugCaptureRadarFiledMetricKeyProfile,
                            _kRTBugCaptureRadarFiledMetricKeyReason,
                            _kRTRadarUtilitiesRadarTitlePrefix,
                            _kRTTransactionMetricsKeyActiveTransactions,
                            _kRTTransactionMetricsKeyDuration,
                            _kRTTransactionMetricsKeyMemoryFootprintDelta,
                            _kRTTransactionMetricsKeyMemoryFootprintEnd,
                            _kRTTransactionMetricsKeyMemoryFootprintStart,
                            _kRTTransactionMetricsKeyName,
                            _kRTTransactionMetricsKeyOnBehalfOf,
                            _kRTTransactionMetricsKeyProcess,
                            _kRTTransactionMetricsKeyState ]
    objc-classes:         [ RTBugCaptureConfiguration, RTBugCaptureManager,
                            RTBugCaptureMetricsManager, RTHangsMetrics,
                            RTRadarUtilities, RTTransaction,
                            RTTransactionExpectations, RTTransactionManager,
                            RTTransactionMetricsManager, RTTransactionOptions,
                            RTTransactionProfileData ]
    objc-ivars:           [ RTBugCaptureConfiguration._enabled,
                            RTBugCaptureConfiguration._internalInstall,
                            RTBugCaptureConfiguration._profile,
                            RTBugCaptureConfiguration._storageDelegate,
                            RTBugCaptureManager._configuration,
                            RTBugCaptureManager._inMemoryFilingState,
                            RTBugCaptureManager._metricsManager,
                            RTBugCaptureManager._queue,
                            RTBugCaptureMetricsManager._metrics,
                            RTBugCaptureMetricsManager._storageDelegate,
                            RTTransaction._identifier, RTTransaction._name,
                            RTTransaction._options, RTTransaction._osTransaction,
                            RTTransaction._profileData, RTTransaction._state,
                            RTTransaction._transactionError,
                            RTTransactionExpectations._durationThreshold,
                            RTTransactionExpectations._memoryThreshold,
                            RTTransactionManager._activeTransactions,
                            RTTransactionManager._bugCaptureManager,
                            RTTransactionManager._metricsManager,
                            RTTransactionManager._monitoringInterval,
                            RTTransactionManager._monitoringTimer,
                            RTTransactionManager._queue,
                            RTTransactionManager._transactionDiagnosticsSampled,
                            RTTransactionMetricsManager._cachedMetricsEnabled,
                            RTTransactionOptions._expectations,
                            RTTransactionOptions._onBehalfOf,
                            RTTransactionOptions._optionsMask,
                            RTTransactionOptions._process,
                            RTTransactionProfileData._bugCaptureTriggered,
                            RTTransactionProfileData._endDate,
                            RTTransactionProfileData._endMemoryUsage,
                            RTTransactionProfileData._peakMemoryUsage,
                            RTTransactionProfileData._signpostId,
                            RTTransactionProfileData._startDate,
                            RTTransactionProfileData._startMemoryUsage ]
...
