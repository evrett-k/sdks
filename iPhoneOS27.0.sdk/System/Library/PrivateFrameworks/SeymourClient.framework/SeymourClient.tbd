--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SeymourClient.framework/SeymourClient
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    re-exports:           [ /System/Library/PrivateFrameworks/SeymourClientFoundation.framework/SeymourClientFoundation ]
    symbols:              [ _SeymourClientVersionNumber,
                            _SeymourClientVersionString ]
    objc-classes:         [ SMCNotify, SMCOSVariant,
                            _TtC13SeymourClient20HealthWorkoutSession,
                            _TtC13SeymourClient25SessionDarwinNotification,
                            _TtC13SeymourClient30AchievementProgressEnvironment ]
...
