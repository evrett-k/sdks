--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/HID.framework/HID
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _HIDVersionNumber, _HIDVersionString,
                            _IOHIDAnalyticsGetConsoleModeStatus,
                            _kHIDUserDevicePropertyCreateInactiveKey ]
    objc-classes:         [ HIDBasicTimeSync, HIDEventSystemClient, HIDLibElement,
                            HIDManager, HIDTimeSync, HIDTransaction, HIDUserDevice,
                            HIDVirtualEventService, IOHIDDeviceClass,
                            IOHIDIUnknown2, IOHIDObsoleteDeviceClass,
                            IOHIDObsoleteQueueClass, IOHIDOutputTransactionClass,
                            IOHIDPlugin, IOHIDQueueClass, IOHIDTransactionClass ]
    objc-ivars:           [ HIDBasicTimeSync._active, HIDBasicTimeSync._clockID,
                            HIDBasicTimeSync._tsClock, HIDBasicTimeSync._tsMgr,
                            HIDEventSystemClient._activated,
                            HIDEventSystemClient._cancelHandler,
                            HIDEventSystemClient._client,
                            HIDEventSystemClient._eventHandler,
                            HIDEventSystemClient._filterHandler,
                            HIDEventSystemClient._handlerLock,
                            HIDEventSystemClient._propertyChangedHandler,
                            HIDEventSystemClient._resetHandler,
                            HIDEventSystemClient._serviceHandler,
                            HIDLibElement._defaultValue, HIDLibElement._element,
                            HIDLibElement._elementStruct,
                            HIDLibElement._isConstant, HIDLibElement._isUpdated,
                            HIDLibElement._psKey, HIDManager._activated,
                            HIDManager._cancelHandler,
                            HIDManager._deviceNotificationHandler,
                            HIDManager._elementHandler, HIDManager._handlerLock,
                            HIDManager._inputReportHandler, HIDManager._manager,
                            HIDTimeSync._cancelHandler, HIDTimeSync._client,
                            HIDTimeSync._device, HIDTimeSync._eventHandler,
                            HIDTimeSync._propertyNotify,
                            HIDTimeSync._propertyPort, HIDTimeSync._queue,
                            HIDTimeSync._service, HIDTimeSync._state,
                            HIDTransaction._transaction,
                            HIDUserDevice._cancelHandler, HIDUserDevice._device,
                            HIDUserDevice._getReportHandler,
                            HIDUserDevice._service,
                            HIDUserDevice._setReportHandler,
                            HIDVirtualEventService._client,
                            HIDVirtualEventService._delegate,
                            HIDVirtualEventService._queue,
                            HIDVirtualEventService._serviceClient,
                            HIDVirtualEventService._state,
                            IOHIDDeviceClass._callbackLock,
                            IOHIDDeviceClass._connect, IOHIDDeviceClass._device,
                            IOHIDDeviceClass._deviceLock,
                            IOHIDDeviceClass._elements,
                            IOHIDDeviceClass._inputReportBuffer,
                            IOHIDDeviceClass._inputReportBufferLength,
                            IOHIDDeviceClass._inputReportCallback,
                            IOHIDDeviceClass._inputReportContext,
                            IOHIDDeviceClass._inputReportTimestampCallback,
                            IOHIDDeviceClass._machPort, IOHIDDeviceClass._opened,
                            IOHIDDeviceClass._pendingCallbacks,
                            IOHIDDeviceClass._port, IOHIDDeviceClass._properties,
                            IOHIDDeviceClass._queue,
                            IOHIDDeviceClass._reportElements,
                            IOHIDDeviceClass._runLoopSource,
                            IOHIDDeviceClass._service,
                            IOHIDDeviceClass._sortedElements,
                            IOHIDDeviceClass._tccGranted,
                            IOHIDDeviceClass._tccRequested, IOHIDIUnknown2._vtbl,
                            IOHIDObsoleteDeviceClass._interface,
                            IOHIDObsoleteDeviceClass._notification,
                            IOHIDObsoleteDeviceClass._notifyPort,
                            IOHIDObsoleteDeviceClass._removalCallback,
                            IOHIDObsoleteDeviceClass._removalRefcon,
                            IOHIDObsoleteDeviceClass._removalTarget,
                            IOHIDObsoleteDeviceClass._reportCallback,
                            IOHIDObsoleteDeviceClass._reportCallbackRefcon,
                            IOHIDObsoleteDeviceClass._reportCallbackTarget,
                            IOHIDObsoleteQueueClass._eventCallback,
                            IOHIDObsoleteQueueClass._eventCallbackRefcon,
                            IOHIDObsoleteQueueClass._eventCallbackTarget,
                            IOHIDObsoleteQueueClass._interface,
                            IOHIDOutputTransactionClass._outputInterface,
                            IOHIDPlugin._plugin, IOHIDPlugin._uuid,
                            IOHIDQueueClass._depth, IOHIDQueueClass._device,
                            IOHIDQueueClass._lastTail, IOHIDQueueClass._machPort,
                            IOHIDQueueClass._port, IOHIDQueueClass._queue,
                            IOHIDQueueClass._queueHeader,
                            IOHIDQueueClass._queueLock,
                            IOHIDQueueClass._queueMemory,
                            IOHIDQueueClass._queueMemorySize,
                            IOHIDQueueClass._queueSizeChanged,
                            IOHIDQueueClass._queueToken,
                            IOHIDQueueClass._runLoopSource,
                            IOHIDQueueClass._usageAnalytics,
                            IOHIDQueueClass._valueAvailableCallback,
                            IOHIDQueueClass._valueAvailableContext,
                            IOHIDTransactionClass._callbackLock,
                            IOHIDTransactionClass._device,
                            IOHIDTransactionClass._direction,
                            IOHIDTransactionClass._elements,
                            IOHIDTransactionClass._interface,
                            IOHIDTransactionClass._pendingCallbacks ]
