--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/MapsIntelligence.framework/MapsIntelligence
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _GEOConfigMapsIntelligenceTMPDebugMaxIterations,
                            _GEOConfigMapsIntelligenceTMPDebugMaximumSamples,
                            _GEOConfigMapsIntelligenceTMPDebugMinimumSamples,
                            _GEOConfigMapsIntelligenceTMPLearningRate,
                            _GEOConfigMapsIntelligenceTMPMaxIterations,
                            _GEOConfigMapsIntelligenceTMPMaximumTrainingSamples,
                            _GEOConfigMapsIntelligenceTMPMinimumTrainingSamples,
                            _GEOConfigMapsIntelligenceTMPModelFactor,
                            _GEOConfigMapsIntelligenceTMPPersonalizationEnabled,
                            _GEOConfigMapsIntelligenceTMPRetrainingInterval,
                            _GEOConfigMapsIntelligenceTMPSignalInjection,
                            _GEOConfigMapsIntelligenceTMPSignalPList,
                            _MapsIntelligenceVersionNumber,
                            _MapsIntelligenceVersionString,
                            __MapsIntelligenceConfig_MetadataForIdentifier ]
    objc-classes:         [ _TtC16MapsIntelligence25TripSignalFeatureProvider,
                            _TtC16MapsIntelligence27MapsIntelligenceBaseManager,
                            _TtC16MapsIntelligence33MapsIntelligenceSearchRankManager,
                            _TtC16MapsIntelligence46MapsIntelligenceTransportModePredictionManager ]
...
