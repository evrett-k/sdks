                            UARPDeviceManager._uuid,
                            UARPDeviceManager._xpcConnection,
                            UARPDeviceManager._xpcInterface,
                            UARPDeviceTatsuTicket._componentTag,
                            UARPDeviceTatsuTicket._tssRequest,
                            UARPDeviceTatsuTicket._tssResponse,
                            UARPHostEndpointProperties._appleModelNumber,
                            UARPHostEndpointProperties._inactivityTimer,
                            UARPHostEndpointProperties._packetRetries,
                            UARPHostEndpointProperties._packetRetryTimeout,
                            UARPHostEndpointProperties._productGroup,
                            UARPHostEndpointProperties._productNumber,
                            UARPHostEndpointProperties._supportsCharging,
                            UARPHostEndpointProperties._supportsSiri,
                            UARPHostEndpointProperties._supportsVoiceAssist ]
