--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/EXSurface.framework/EXSurface
current-version:       1.5
compatibility-version: 1.2
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _EXSurfaceFakeRootName,
                            _EXSurfaceProxyCreateWithDarwinID,
                            _EXSurfaceProxyCreateWithFakeDarwinID,
                            _EXSurfaceProxyGetDarwinID,
                            _EXSurfaceProxyGetRootName, _EXSurfaceProxyGetTypeID,
                            _EXSurfaceRangeAllocatorAllocate,
                            _EXSurfaceRangeAllocatorAllocateRange,
                            _EXSurfaceRangeAllocatorDeallocate,
                            _EXSurfaceRangeAllocatorDestroy,
                            _EXSurfaceRangeAllocatorGetFragmentCapacity,
                            _EXSurfaceRangeAllocatorGetFragmentCount,
                            _EXSurfaceRangeAllocatorGetFreeSize,
                            _EXSurfaceRangeAllocatorGetMaxFreeSize,
                            _EXSurfaceRangeAllocatorInit,
                            _EXSurfaceRangeAllocatorInitWithStartRange,
                            _EXSurfaceRangeAllocatorSetFragmentCapacityIncrement,
                            __exsfc_atomic_uint64_increment_relaxed,
                            _kEXSurfaceFakeRootName ]
    objc-classes:         [ EXSurface, EXSurfaceDescriptor,
                            EXSurfaceImageDescriptor, EXSurfaceMemory,
                            EXSurfaceMemoryRegion, EXSurfacePlane,
                            EXSurfacePlaneArray, EXSurfacePlaneDescriptorArray,
                            EXSurfacePriv, EXSurfacePrivImageDesc,
                            EXSurfacePrivImageDescArray, EXSurfaceProxy,
                            _EXSurfacePriv ]
    objc-ivars:           [ EXSurface._planes, EXSurface._priv,
                            EXSurfaceDescriptor._allocationAlignment,
                            EXSurfaceDescriptor._allocationSize,
                            EXSurfaceDescriptor._memoryRegion,
                            EXSurfaceDescriptor._pixelFormat,
                            EXSurfaceDescriptor._planeCount,
                            EXSurfaceDescriptor._planes,
                            EXSurfaceImageDescriptor._private,
                            EXSurfaceMemory._alignment, EXSurfaceMemory._dealloc,
                            EXSurfaceMemory._memoryRegion,
                            EXSurfaceMemory._offset, EXSurfaceMemory._size,
                            EXSurfaceMemoryRegion._baseAddress,
                            EXSurfaceMemoryRegion._lock,
                            EXSurfaceMemoryRegion._numAllocated,
                            EXSurfaceMemoryRegion._rangeAllocator,
                            EXSurfaceMemoryRegion._sharedMemoryRegionID,
                            EXSurfacePlane._planeIndex, EXSurfacePlane._priv,
                            EXSurfacePlaneArray._planes,
                            EXSurfacePlaneArray._priv,
                            EXSurfacePlaneDescriptorArray._planes,
                            EXSurfacePriv._ioSurface,
                            EXSurfacePrivImageDesc._bytesPerElement,
                            EXSurfacePrivImageDesc._bytesPerRow,
                            EXSurfacePrivImageDesc._elementHeight,
                            EXSurfacePrivImageDesc._elementWidth,
                            EXSurfacePrivImageDesc._height,
                            EXSurfacePrivImageDesc._offset,
                            EXSurfacePrivImageDesc._size,
                            EXSurfacePrivImageDesc._width,
                            EXSurfacePrivImageDescArray._planeCount,
                            EXSurfacePrivImageDescArray._planes,
                            EXSurfaceProxy._darwinID, EXSurfaceProxy._port,
                            EXSurfaceProxy._rootName,
                            _EXSurfacePriv._allocationAlignment,
                            _EXSurfacePriv._allocationOffset,
                            _EXSurfacePriv._allocationSize,
                            _EXSurfacePriv._baseAddress,
                            _EXSurfacePriv._imageDesc, _EXSurfacePriv._memory,
                            _EXSurfacePriv._memoryRegion,
                            _EXSurfacePriv._pixelFormat,
                            _EXSurfacePriv._planeCount,
                            _EXSurfacePriv._planeData, _EXSurfacePriv._surfaceID,
                            _EXSurfacePriv._useCount ]
...
