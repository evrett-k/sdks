                            _TtC23TCCAuthorizationService22BluetoothAlwaysService,
                            _TtC23TCCAuthorizationService22SpeechDictationService,
                            _TtC23TCCAuthorizationService27AuthorizationResultListener,
                            _TtC23TCCAuthorizationService28AuthorizationResultPublisher,
                            _TtC23TCCAuthorizationService32AuthorizationPromptServiceServer ]
