--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/PencilFeedback.framework/PencilFeedback
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _NoiseGeneratorCreate,
                            _NoiseGeneratorGetRenderCallback,
                            _NoiseGeneratorRelease, _NoiseGeneratorRetain,
                            _NoiseGeneratorSetAmplitude,
                            _NoiseGeneratorSetAmplitudeWithRamp,
                            _NoiseGeneratorSetPaused, _PFInputPointZero,
                            _PFSignpostAudioParameters, _PFSignpostAudioRealtime,
                            _PFSignpostInit, _PFSignpostInputProcessing,
                            _PFSignpostLifecycle, _PFSignpostSmoothing,
                            _PFToolTypeToString, _PencilFeedbackVersionNumber,
                            _PencilFeedbackVersionString, _readValueFromDefaults ]
    objc-classes:         [ PFBezierMapping, PFPencilSoundManager,
                            PFPencilSoundProfile, PFPencilSoundProfileFactory,
                            PFQuadPanAudioUnit, PFQuadPanAudioUnitImpl,
                            PFSoundGeneratorAVAE, PFSoundGeneratorBase,
                            PFSoundGeneratorPHASE, PFSoundXYPanner ]
    objc-ivars:           [ PFBezierMapping._controlPoint1,
                            PFBezierMapping._controlPoint2,
                            PFBezierMapping._controlPoint3,
                            PFPencilSoundManager._audioQueue,
                            PFPencilSoundManager._bufferSize,
                            PFPencilSoundManager._currentAzimuth,
                            PFPencilSoundManager._currentMapping,
                            PFPencilSoundManager._currentProfile,
                            PFPencilSoundManager._currentTool,
                            PFPencilSoundManager._horizontalSpread,
                            PFPencilSoundManager._idleTimer,
                            PFPencilSoundManager._interfaceOrientation,
                            PFPencilSoundManager._lastRoll,
                            PFPencilSoundManager._normalizedPickerThickness,
                            PFPencilSoundManager._profileFactory,
                            PFPencilSoundManager._soundGenerator,
                            PFPencilSoundManager._soundParameters,
                            PFPencilSoundManager._useMagicNumbers,
                            PFPencilSoundManager._useRoll,
                            PFPencilSoundManager._verticalSpread,
                            PFPencilSoundManager.touchBuffer,
                            PFPencilSoundProfile._baseBPBandwidth,
                            PFPencilSoundProfile._baseBPFrequency,
                            PFPencilSoundProfile._baseHPFrequency,
                            PFPencilSoundProfile._baseLPFrequency,
                            PFPencilSoundProfile._controlPoint1,
                            PFPencilSoundProfile._controlPoint2,
                            PFPencilSoundProfile._controlPoint3,
                            PFPencilSoundProfile._directionFrequencyDeviation,
                            PFPencilSoundProfile._fixedGain,
                            PFPencilSoundProfile._forceFrequencyDeviation,
                            PFPencilSoundProfile._maxThickness,
                            PFPencilSoundProfile._minThickness,
                            PFPencilSoundProfile._originalDirectionValue,
                            PFPencilSoundProfile._thicknessFrequencyRange,
                            PFPencilSoundProfile._velocityFrequencyAddAmount,
                            PFPencilSoundProfile._velocityRatio,
                            PFPencilSoundProfileFactory._currentProfile,
                            PFQuadPanAudioUnit._audioUnitImpl,
                            PFQuadPanAudioUnitImpl._algorithm,
                            PFQuadPanAudioUnitImpl._currentGains,
                            PFQuadPanAudioUnitImpl._horizontalPan,
                            PFQuadPanAudioUnitImpl._inputBusArray,
                            PFQuadPanAudioUnitImpl._outputBusArray,
                            PFQuadPanAudioUnitImpl._parameterTree,
                            PFQuadPanAudioUnitImpl._previousGains,
                            PFQuadPanAudioUnitImpl._verticalPan,
                            PFSoundGeneratorAVAE._bandPassFilter,
                            PFSoundGeneratorAVAE._crossoverLowPassFilter,
                            PFSoundGeneratorAVAE._engine,
                            PFSoundGeneratorAVAE._highPassFilter,
                            PFSoundGeneratorAVAE._isAudioActive,
                            PFSoundGeneratorAVAE._lowPassFilter,
                            PFSoundGeneratorAVAE._monoFormat,
                            PFSoundGeneratorAVAE._noiseGenerator,
                            PFSoundGeneratorAVAE._noiseSourceNode,
                            PFSoundGeneratorAVAE._panner,
                            PFSoundGeneratorBase._auxiliarySession,
                            PFSoundGeneratorBase._bandpassFrequency,
                            PFSoundGeneratorBase._bandwidth,
                            PFSoundGeneratorBase._channelCount,
                            PFSoundGeneratorBase._crossoverFrequency,
                            PFSoundGeneratorBase._currentVolumeState,
                            PFSoundGeneratorBase._gainNormalizationDivisor,
                            PFSoundGeneratorBase._highPassFrequency,
                            PFSoundGeneratorBase._lowPassFrequency,
                            PFSoundGeneratorBase._outputVolume,
                            PFSoundGeneratorBase._panHorizontal,
                            PFSoundGeneratorBase._panVertical,
                            PFSoundGeneratorBase._strokeVolume,
                            PFSoundGeneratorPHASE._dataBundleAsset,
                            PFSoundGeneratorPHASE._engine,
                            PFSoundGeneratorPHASE._isAudioActive,
                            PFSoundGeneratorPHASE._soundEvent,
                            PFSoundXYPanner._outputFormat,
                            PFSoundXYPanner._quadPannerAU,
                            PFSoundXYPanner._stereoMixer ]
...
