--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AccessoryLiveActivitiesUI.framework/AccessoryLiveActivitiesUI
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _AccessoryLiveActivitiesUIVersionNumber,
                            _AccessoryLiveActivitiesUIVersionString ]
    objc-classes:         [ ALActivitySettingsDetailExtension,
                            AccessorySettingsDataProvider ]
    objc-ivars:           [ ALActivitySettingsDetailExtension._bundleIdentifier,
                            ALActivitySettingsDetailExtension._dataProvider,
                            ALActivitySettingsDetailExtension._devices,
                            ALActivitySettingsDetailExtension._forwardingEnabled,
                            ALActivitySettingsDetailExtension._reloadBlock ]
...
