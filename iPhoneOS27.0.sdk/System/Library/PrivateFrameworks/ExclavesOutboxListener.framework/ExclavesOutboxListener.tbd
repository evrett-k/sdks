--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/ExclavesOutboxListener.framework/ExclavesOutboxListener
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _ExclavesOutboxListenerVersionNumber,
                            _ExclavesOutboxListenerVersionString,
                            __cancel_exclaves_notification_source,
                            __create_exclaves_notification_source,
                            __exclaves_nofitication_source_activate_with_handler ]
...
