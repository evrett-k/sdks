--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AccessibilityPhysicalInteraction.framework/AccessibilityPhysicalInteraction
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _AXPIChangeActiveCategoryVolume,
                            _AXPIDefaultAppearanceForDevice,
                            _AXPIDistanceBetweenPoints, _AXPIFingerDownDelay,
                            _AXPIGesturePointNull, _AXPIGetSilentMode,
                            _AXPILocalizedString,
