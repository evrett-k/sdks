                            _AXPISetSilentMode,
                            _AXPISystemActionHelperClientBackTap,
                            _AXPISystemPointerSize,
                            _AccessibilityPhysicalInteractionVersionNumber,
                            _AccessibilityPhysicalInteractionVersionString ]
