--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SensingAlgsService.framework/SensingAlgsService
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    objc-classes:         [ BrailleModeObserver, SASInterfaceTouch ]
    objc-ivars:           [ BrailleModeObserver._brailleEnabled,
                            SASInterfaceTouch._atomic_wake_event,
                            SASInterfaceTouch._brailleModeObserver,
                            SASInterfaceTouch._configurationCallback,
                            SASInterfaceTouch._cont_abs_diff,
                            SASInterfaceTouch._coreAnalyticsCallback,
                            SASInterfaceTouch._cover_gesture,
                            SASInterfaceTouch._cover_gesture_state,
                            SASInterfaceTouch._currentBrailleState,
                            SASInterfaceTouch._device,
                            SASInterfaceTouch._duration_between_touches,
                            SASInterfaceTouch._emptyPaths,
                            SASInterfaceTouch._eventCallback,
                            SASInterfaceTouch._event_info_array,
                            SASInterfaceTouch._event_info_array_descriptor,
                            SASInterfaceTouch._finger_events_array,
                            SASInterfaceTouch._finger_events_array_descriptor,
                            SASInterfaceTouch._finger_events_size,
                            SASInterfaceTouch._hand_event_array,
                            SASInterfaceTouch._hand_event_array_descriptor,
                            SASInterfaceTouch._hts_delta_ms,
                            SASInterfaceTouch._inputBuffer,
                            SASInterfaceTouch._last_frame_time_us,
                            SASInterfaceTouch._outputBuffer,
                            SASInterfaceTouch._path_stats,
                            SASInterfaceTouch._pencilEventCallback,
                            SASInterfaceTouch._phone_telemetry,
                            SASInterfaceTouch._planId,
                            SASInterfaceTouch._pre_hysteresis_ff_angles,
                            SASInterfaceTouch._prev_frame_diff_us,
                            SASInterfaceTouch._propertyDatabase,
                            SASInterfaceTouch._ptw,
                            SASInterfaceTouch._resetRequestCallback,
                            SASInterfaceTouch._streamCallback,
                            SASInterfaceTouch._stylus,
                            SASInterfaceTouch._stylusHand,
                            SASInterfaceTouch._tap,
                            SASInterfaceTouch._timestamp_offset,
                            SASInterfaceTouch._touch_system_ready,
                            SASInterfaceTouch._versions,
                            SASInterfaceTouch._wake_event_detected ]
...
