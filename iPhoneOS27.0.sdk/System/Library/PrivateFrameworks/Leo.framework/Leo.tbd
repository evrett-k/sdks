                            _LEOItemTypeIsCollection,
                            _LEOLexemeCategoryFromInteger, _LEOLexemeIDMax,
                            _LEOStringForLeoItemType,
                            _LEOStringForLexemeCategory, _LEOStringForLexemeType ]
