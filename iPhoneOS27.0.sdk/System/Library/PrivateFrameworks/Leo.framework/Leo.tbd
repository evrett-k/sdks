--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/Leo.framework/Leo
current-version:       910.33.102
compatibility-version: 1
objc-constraint:       retain_release
exports:
