                            LEOGeoRect, LEOGeoRegion, LEOGeohash, LEOItem,
                            LEOItemLexemeDetails, LEOItemQuery, LEOItemQueryResult,
                            LEOItemQueryToken, LEOLexeme, LEONLTokenizer,
                            LEOQueryOptions, LEOWritableAttributeContext,
                            _LEOIndexedItem ]
