                            LEOGeoRect._lon2, LEOGeoRegion._geometry,
                            LEOGeoRegion._index, LEOGeoRegion._indexGenerated,
                            LEOGeohash._geohashString, LEOGeohash._precision,
                            LEOItem._dateCreated, LEOItem._identifier,
                            LEOItem._thumbnailData, LEOItem._type,
                            LEOItemLexemeDetails._isMatch,
                            LEOItemLexemeDetails._lexemeID,
                            LEOItemLexemeDetails._score,
                            LEOItemQuery._computeMatchedLexemeCounts,
                            LEOItemQuery._fetchedDetails,
                            LEOItemQuery._fetchedLexemeIDsBitset,
                            LEOItemQuery._includeFetchedLexemeDetails,
                            LEOItemQuery._lexemeIDToLexemeSetMatchCounterIndexes,
                            LEOItemQuery._lexemeIDtoMatchedCount,
                            LEOItemQuery._lexemeSetMatchCounters,
                            LEOItemQuery._lexemeSetMaxMatchCounts,
                            LEOItemQuery._lexemeSetMinMatchCounts,
                            LEOItemQuery._operands, LEOItemQuery._options,
                            LEOItemQuery._queryBitset, LEOItemQuery._queryID,
                            LEOItemQuery._queryOperandsCount,
                            LEOItemQuery._queryTokens, LEOItemQuery._stack,
                            LEOItemQuery._tokens,
                            LEOItemQueryResult._matchedLexemeIDCounts,
                            LEOItemQueryResult._resultItems,
                            LEOItemQueryToken._lexemeIDs,
                            LEOItemQueryToken._maxCount,
                            LEOItemQueryToken._minCount, LEOItemQueryToken._op,
                            LEOItemQueryToken._type,
                            LEONLTokenizer._apostrophesToStrip,
                            LEONLTokenizer._tokenizer,
                            LEOQueryOptions._computeMatchedLexemeCounts,
                            LEOQueryOptions._fetchedLexemeIDs,
                            LEOQueryOptions._includeContextualThumbnailData,
                            LEOQueryOptions._includeScores,
                            LEOQueryOptions._itemTypes,
                            LEOQueryOptions._logIdentifier,
                            LEOQueryOptions._sortDescriptor ]
...
