--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SpeechEngine.framework/SpeechEngine
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _SpeechEngineVersionNumber,
                            _SpeechEngineVersionString,
                            _accelerate_bnns_graph_clear_model_tensors,
                            _accelerate_bnns_graph_compile,
                            _accelerate_bnns_graph_delete_model,
                            _accelerate_bnns_graph_dictation_dynamic_retriever_set_text_length,
                            _accelerate_bnns_graph_execute,
                            _accelerate_bnns_graph_get_tensor_count,
                            _accelerate_bnns_graph_get_tensor_data,
                            _accelerate_bnns_graph_get_tensor_fp16_to_fp32,
                            _accelerate_bnns_graph_get_tensor_int32_to_fp32,
                            _accelerate_bnns_graph_get_tensor_names,
                            _accelerate_bnns_graph_get_tensor_shape,
                            _accelerate_bnns_graph_get_tensor_size_bytes,
                            _accelerate_bnns_graph_init_tensors,
                            _accelerate_bnns_graph_load_model,
                            _accelerate_bnns_graph_prewarm_pages,
                            _accelerate_bnns_graph_set_tensor_data,
                            _accelerate_bnns_graph_set_tensor_fp32_to_fp16,
                            _accelerate_bnns_graph_swap_tensors_pointers,
                            _accelerate_bnns_graph_tts_depthformer_v4_encoder_split_output,
                            _accelerate_bnns_graph_tts_depthformer_v6_encoder_split_output,
                            _accelerate_bnns_graph_tts_depthformer_v6_mti_encoder_split_output,
                            _current_thread_priority,
                            _workgroup_helper_workloop_create,
                            _workgroup_interval_create_with_workload,
                            _workgroup_interval_start_with_utilization ]
    objc-classes:         [ _TtC12SpeechEngine16FeatureExtractor ]
...
