--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AppleAccountTransparency.framework/AppleAccountTransparency
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    objc-classes:         [ _TtC24AppleAccountTransparency19AATDaemonConnection,
                            _TtC24AppleAccountTransparency20AATConnectionManager,
                            _TtC24AppleAccountTransparency20StoreMigratorAdapter,
                            _TtC24AppleAccountTransparency22AATransparencyEventXPC,
                            _TtC24AppleAccountTransparency27AATransparencyDaemonService ]
...
