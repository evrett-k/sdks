                            _TtC29AssistantActionSuggestionCore20AssistantActionEvent,
                            _TtC29AssistantActionSuggestionCore30PromptSuggestionMergingManager,
                            _TtC29AssistantActionSuggestionCore31AssistantActionSuggestionLogger,
                            _TtC29AssistantActionSuggestionCore44ConversationIndexManagerSingletonInitializer ]
