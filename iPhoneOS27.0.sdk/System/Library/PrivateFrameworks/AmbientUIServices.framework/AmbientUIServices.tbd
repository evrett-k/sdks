                            AMUIAmbientInteractionEventAction,
                            AMUIAmbientPosterScenePresentationTriggerSuspensionAction,
                            AMUIAmbientPosterSceneUnlockRequestAction,
                            AMUIAmbientPresentationSceneClientComponent,
                            AMUIAmbientPresentationSceneExtension,
                            AMUIAmbientPresentationSettingsExtension,
                            AMUIAmbientPresentationStateTrait,
                            _TtC17AmbientUIServices27AmbientPosterSceneExtension,
                            _TtC17AmbientUIServices31AmbientPosterSceneHostComponent,
                            _TtC17AmbientUIServices33AmbientPosterSceneClientComponent,
                            _TtC17AmbientUIServices39AmbientPosterSceneHostSettingsExtension,
                            _TtC17AmbientUIServices41AmbientPosterSceneClientSettingsExtension ]
    objc-ivars:           [ AMUIAmbientPresentationSceneClientComponent._ambientDisplayStyle,
                            AMUIAmbientPresentationSceneClientComponent._ambientPresented ]
...
