--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/BrainTrust.framework/BrainTrust
current-version:       2718.0.12
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _BrainTrustErrorDomain,
                            _amfi_check_dyld_policy_for_pid,
                            _amfi_check_dyld_policy_self, _amfi_load_trust_cache,
                            _amfi_unload_trust_cache ]
    objc-classes:         [ BrainTrust, BrainTrustBuilder, BrainTrustEnvironment,
                            BrainTrustError, BrainTrustOverrides,
                            BrainTrustPersonalization, BrainTrustPreferences ]
    objc-ivars:           [ BrainTrust._allowUserInteraction,
                            BrainTrust._buildTrain, BrainTrust._buildVersion,
                            BrainTrust._destinationBundlePath,
                            BrainTrust._environment, BrainTrust._environmentType,
                            BrainTrust._overrides, BrainTrust._signingServerURL,
                            BrainTrust._sourceBundlePath, BrainTrust._ssoToken,
                            BrainTrust._type, BrainTrustBuilder._environmentType,
                            BrainTrustBuilder._outputBundlePath,
                            BrainTrustBuilder._productClassOverride,
                            BrainTrustBuilder._trustCache,
                            BrainTrustEnvironment._ECID,
                            BrainTrustEnvironment._boardID,
                            BrainTrustEnvironment._certificateEpoch,
                            BrainTrustEnvironment._chipID,
                            BrainTrustEnvironment._contextType,
                            BrainTrustEnvironment._cryptex1ChipId,
                            BrainTrustEnvironment._cryptex1NonceDomain,
                            BrainTrustEnvironment._cryptex1ProductClass,
                            BrainTrustEnvironment._cryptex1Type,
                            BrainTrustEnvironment._effectiveProductionMode,
                            BrainTrustEnvironment._effectiveSecurityMode,
                            BrainTrustEnvironment._nonceType,
                            BrainTrustEnvironment._productionMode,
                            BrainTrustEnvironment._securityDomain,
                            BrainTrustEnvironment._securityMode,
                            BrainTrustEnvironment._type,
                            BrainTrustOverrides._debugServerTransactions,
                            BrainTrustOverrides._dstBundlePath,
                            BrainTrustOverrides._signingServerURL,
                            BrainTrustOverrides._skipCleanup,
                            BrainTrustOverrides._skipCopyNonceDigest,
                            BrainTrustOverrides._skipLoadTrustCache,
                            BrainTrustOverrides._skipPersonalization,
                            BrainTrustPersonalization._amai,
                            BrainTrustPersonalization._bundleURL,
                            BrainTrustPersonalization._debugServerTransactions,
                            BrainTrustPersonalization._environment,
                            BrainTrustPersonalization._signingServerURL,
                            BrainTrustPersonalization._ssoToken,
                            BrainTrustPersonalization._uuid ]
...
