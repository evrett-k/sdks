--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AssistantIsland.framework/AssistantIsland
current-version:       73.0.12
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _AIAssistantIslandStateIsActivity,
                            _AIAssistantIslandStateMaskContainsState,
                            _AIAssistantIslandStateMaskFromState,
                            _AIRemoteGestureStateEqualsState,
                            _AIRemoteGestureStateFromBSSettings,
                            _AIRemoteGestureStateIsUnspecified,
                            _AIRemoteGestureStateNew,
                            _AIRemoteGestureStateToBSSettings,
                            _AIRemoteGestureStateUnspecified,
                            _NSStringFromAIAssistantIslandState ]
    objc-classes:         [ AIActivateAppSceneActionHelper, AIIslandCoordinator,
                            AIMockWorkspaceService,
                            AIMockWorkspaceServiceDelegate,
                            AIMutableWorkspaceServiceRequest, AIRemoteGesture,
                            AIRemoteGestureBeginAction, AIRemoteGestureEndAction,
                            AIRemoteGestureReader, AIRemoteGestureWriter,
                            AIStageSceneSpecification, AIStageTransitionRequest,
                            AIStageTransitionRequestAction,
                            AIWorkspaceEnvironment, AIWorkspaceEnvironmentState,
                            AIWorkspaceService, AIWorkspaceServiceRequest,
                            _TtC15AssistantIsland12SiriWaveView,
                            _TtC15AssistantIsland12StageGesture,
                            _TtC15AssistantIsland12StageSDFView,
                            _TtC15AssistantIsland14StageViewModel,
                            _TtC15AssistantIsland15StagePanGesture,
                            _TtC15AssistantIsland16DrivingFocusView,
                            _TtC15AssistantIsland16StageContentView,
                            _TtC15AssistantIsland17SiriWaveLayerView,
                            _TtC15AssistantIsland17StageBackdropView,
                            _TtC15AssistantIsland17StageGradientView,
                            _TtC15AssistantIsland18StageAccessoryView,
                            _TtC15AssistantIsland18StageLayoutManager,
                            _TtC15AssistantIsland19StageGestureContext,
                            _TtC15AssistantIsland19StageSDFElementView,
                            _TtC15AssistantIsland19StageSceneExtension,
                            _TtC15AssistantIsland21PresentGestureContext,
                            _TtC15AssistantIsland21WeakDisplayLinkTarget,
                            _TtC15AssistantIsland22ResponseGestureContext,
                            _TtC15AssistantIsland22StageLayoutTransaction,
                            _TtC15AssistantIsland23StageGestureTransaction,
                            _TtC15AssistantIsland23StageSceneHostComponent,
                            _TtC15AssistantIsland24AssistantIslandWorkspace,
                            _TtC15AssistantIsland24StageHitTestBlockingView,
                            _TtC15AssistantIsland25StageSceneClientComponent,
                            _TtC15AssistantIsland25StageTouchPassThroughView,
                            _TtC15AssistantIsland27DragStageGestureTransaction,
                            _TtC15AssistantIsland27StageContentOrbElementsView,
                            _TtC15AssistantIsland27StageSceneSettingsExtension,
                            _TtC15AssistantIsland27StageViewModelSceneObserver,
                            _TtC15AssistantIsland29StageOrbSDFElementWrapperView,
                            _TtC15AssistantIsland30PresentGestureStageTransaction,
                            _TtC15AssistantIsland30PresentationGestureInteraction,
                            _TtC15AssistantIsland31AssistantIslandAppSceneDelegate,
                            _TtC15AssistantIsland33StageSceneClientSettingsExtension,
                            _TtC15AssistantIsland38DismissActivityGestureStageTransaction,
                            _TtC15AssistantIsland9StageView ]
    objc-ivars:           [ AIMockWorkspaceServiceDelegate._handler,
                            AIRemoteGesture._clientDisplayLink,
                            AIRemoteGesture._clientLastUpdateNanostamp,
                            AIRemoteGesture._clientLifecycleAssertion,
                            AIRemoteGesture._clientReaderIsValid,
                            AIRemoteGesture._componentDelegate,
                            AIRemoteGesture._hasSentGestureBeginEvent,
                            AIRemoteGesture._invalidated, AIRemoteGesture._phase,
                            AIRemoteGesture._reader, AIRemoteGesture._scene,
                            AIRemoteGesture._selectedItemIdentifier,
                            AIRemoteGesture._state, AIRemoteGesture._type,
                            AIRemoteGesture._writer,
                            AIRemoteGestureReader._invalidated,
                            AIRemoteGestureReader._mappedSize,
                            AIRemoteGestureReader._sharedMemory,
                            AIRemoteGestureReader._sharedMemoryObject,
                            AIRemoteGestureWriter._allocatedSize,
                            AIRemoteGestureWriter._invalidated,
                            AIRemoteGestureWriter._sharedMemory,
                            AIRemoteGestureWriter._sharedMemoryObject,
                            AIStageTransitionRequest._chatSessionIdentifier,
                            AIStageTransitionRequest._defersIfActiveConditionsMet,
                            AIStageTransitionRequest._state,
                            AIWorkspaceService._delegate,
                            AIWorkspaceService._underlying,
                            AIWorkspaceServiceRequest._actions,
                            AIWorkspaceServiceRequest._cachedHashBuilder,
                            AIWorkspaceServiceRequest._modality,
                            AIWorkspaceServiceRequest._presentationStyle,
                            AIWorkspaceServiceRequest._source,
                            AIWorkspaceServiceRequest._targetChatIdentifier ]
