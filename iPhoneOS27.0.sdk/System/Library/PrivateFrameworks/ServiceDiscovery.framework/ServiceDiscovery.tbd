--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/ServiceDiscovery.framework/ServiceDiscovery
current-version:       1
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    objc-classes:         [ SDBTAdvertiser, SDBTDiscoveredDevice, SDBTDiscovery,
                            SDBroadcastStateBridge, SDBroadcastStateComponents,
                            SDDeviceInfo, SDDeviceNetworkInfo,
                            SDServiceAdvertisement, SDServiceDatabase,
                            SDServiceDiscoveryClient, SDServiceDiscoveryDaemon,
                            SDServiceMetadata, SDServiceProvider, SDServiceQuery,
                            SDServiceQueryResult,
                            _TtC16ServiceDiscovery14PersonaMonitor,
                            _TtC16ServiceDiscovery25CloudKitInvitationManager ]
    objc-ivars:           [ SDBTAdvertiser._advertiseRate,
                            SDBTAdvertiser._advertiser,
                            SDBTAdvertiser._dispatchQueue,
                            SDBTAdvertiser._generationCount,
                            SDBTAdvertiser._label, SDBTAdvertiser._rowIndex,
                            SDBTDiscoveredDevice._generationCount,
                            SDBTDiscoveredDevice._identifier,
                            SDBTDiscoveredDevice._rowIndex,
                            SDBTDiscovery._bleScanRate,
                            SDBTDiscovery._deviceChangedHandler,
                            SDBTDiscovery._deviceFilter,
                            SDBTDiscovery._deviceFoundHandler,
                            SDBTDiscovery._deviceLostHandler,
                            SDBTDiscovery._discoveredDevices,
                            SDBTDiscovery._discovery,
                            SDBTDiscovery._dispatchQueue, SDBTDiscovery._label,
                            SDBTDiscovery._useCase ]
...
