--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SpotlightUIShared.framework/SpotlightUIShared
current-version:       236.0.11
compatibility-version: 1
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _SUISCompletionControllerLog, _SUISGeneralLog,
                            _SUISLogSubsystem, _SUISPasteboardIndexingLog,
                            _SUISSelectionControllerLog,
                            _SpotlightContactIdentifierKey,
                            _SpotlightContactUserActivityType,
                            _SpotlightPreferredBundleIDsKey,
                            _SpotlightUISharedVersionNumber,
                            _SpotlightUISharedVersionString ]
    objc-classes:         [ SUIAppIntentsAnnotator, SUIAppIntentsQueryHelper,
                            SUICompletionView, SUICompletionViewController,
                            SUIPseudoSelectionView, SUIQueryContextBuilder,
                            SUISCardLoader, SUISDisplaySignals,
                            SUISFileURLPasteboardExtractor,
                            SUISImageOrPDFPasteboardExtractor,
                            SUISPasteboardExtractor, SUISPasteboardManager,
                            SUISRadarUtilities, SUISStringPasteboardExtractor,
                            SUISWebURLPasteboardExtractor,
                            SUISWindowDisplayPolicy, SUISelectedItem,
                            SUISelectionController, SUISpotlightController,
                            SUITextView, SUIUpdateSearchQueryCommand, SUIUtilities,
                            _TtC17SpotlightUIShared10SUIArchive,
                            _TtC17SpotlightUIShared14BaseTTRManager,
                            _TtC17SpotlightUIShared16AddFilterCommand,
                            _TtC17SpotlightUIShared22FilesZKWFallbackResult,
                            _TtC17SpotlightUIShared24SpotlightQueryDataSource,
                            _TtC17SpotlightUIShared27ParameterSuggestionsManager,
                            _TtC17SpotlightUIShared29SpotlightIndexQueryDataSource,
                            _TtC17SpotlightUIShared32LocationParameterQueryDataSource,
                            _TtC17SpotlightUIShared32SUIPerformAppBrowseFilterCommand,
                            _TtC17SpotlightUIShared34PrimitiveTypedValueResultViewModel,
                            _TtC17SpotlightUIShared36PrimitiveTypedValueResultHostingView ]
    objc-ivars:           [ SUICompletionView._overlayTextView,
                            SUICompletionViewController._attributedQueryString,
                            SUICompletionViewController._delegate,
                            SUICompletionViewController._dummySizingTextView,
                            SUICompletionViewController._font,
                            SUICompletionViewController._overlayTextView,
                            SUICompletionViewController._pseudoSelectionView,
                            SUICompletionViewController._punchoutIconDimension,
                            SUICompletionViewController._punchoutIconImageView,
                            SUICompletionViewController._selectedItem,
                            SUISPasteboardManager._changeCount,
                            SUISPasteboardManager._foundItems,
                            SUISPasteboardManager._isNothingDispatchedForNextExpiration,
                            SUISPasteboardManager._pasteboardHistoryItemWasCopied,
                            SUISPasteboardManager._publisher,
                            SUISPasteboardManager._scheduler,
                            SUISPasteboardManager._sink,
                            SUISPasteboardManager._stream,
                            SUISelectedItem._cardSection,
                            SUISelectedItem._isAskSiri, SUISelectedItem._result,
                            SUISelectionController._delegate,
                            SUISelectionController._isCursorAtEnd,
                            SUISelectionController._lastQuery,
                            SUISelectionController._preventAutoSelectionUpdates,
                            SUISelectionController._selectedItem,
                            SUISpotlightController._appDelegate,
                            SUISpotlightController._clientSession,
                            SUISpotlightController._currentSearchString,
                            SUISpotlightController._feedbackDelegate,
                            SUISpotlightController._resultsViewDelegate,
                            SUISpotlightController._searchFieldDelegate,
                            SUIUpdateSearchQueryCommand._queryKind ]
