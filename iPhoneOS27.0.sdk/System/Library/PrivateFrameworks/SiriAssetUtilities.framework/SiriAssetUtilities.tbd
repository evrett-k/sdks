                            SAUAssetUtilitiesService._completionWatchdogInProgress,
                            SAUAssetUtilitiesService._dictationStatus,
                            SAUAssetUtilitiesService._downloadQueue,
                            SAUAssetUtilitiesService._observerEnabled,
                            SAUAssetUtilitiesService._queuesArePaused,
                            SAUAssetUtilitiesService._retryCount,
                            SAUAssetUtilitiesService._siriLanguage,
                            SAUAssetUtilitiesService._statusGroup,
                            SAUAssetUtilitiesService._statusQueue,
                            SAUAssetUtilitiesService._uodAvailable,
                            SAUXPCConnection._queue,
                            SAUXPCConnection._xpcConnection,
                            SAUXPCService._assetUtilitiesService,
