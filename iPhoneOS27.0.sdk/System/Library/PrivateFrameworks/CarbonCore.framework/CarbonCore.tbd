--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/CarbonCore.framework/CarbonCore
current-version:       1
compatibility-version: 1
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _DeclineVolumeNotification,
                            _DeclineVolumeNotificationWithFlags, _DisposeVNUPP,
                            _ErrorTranslate, _FITClientGetEntryInfoFromFileID,
                            _FITClientGetFileIDFromPath,
                            _FITClientGetPathFromFileID,
                            _FITClientGetVRefNumFromDeviceID,
                            _FSCopyURLForVolume, _FSGetCanonicalPath,
                            _FSGetDefaultTextEncoding,
                            _FSMountCopyIOMediaIconBundleIdentifier,
                            _FSMountCopyIOMediaIconFamilyName, _FSMountDestroy,
                            _FSMountGetCapabilities, _FSMountGetFSID,
                            _FSMountGetIOBlockSize, _FSMountGetMaxFileSize,
                            _FSMountGetMountID, _FSMountGetMountPoint,
                            _FSMountGetMutableVolumeInfo,
                            _FSMountGetSpecialDeviceType,
                            _FSMountGetVolumeCreationDate,
                            _FSMountGetVolumeFlags, _FSMountGetVolumeName,
                            _FSMountGetVolumeUUID, _FSMountMakepath,
                            _FSMountMountIDToVRefNum, _FSMountPrepare,
                            _FSMountPrepareWithMountPointString,
                            _FSMountRenameVolume, _FSMountSetProperty,
                            _FSMountStorageSize,
                            _FSMountUpdateCaseInsensitiveName,
                            _FSMountVCBVRefNum, _FSObjTypeToFSNodeObjectType,
                            _FSSetDefaultTextEncoding, _FileIDTreeCanReachServer,
                            _FileIDTreeCreateMountPointArrayWithOptions,
                            _FileIDTreeGetChildIDFromName,
                            _FileIDTreeGetEntryInfoFromFileID,
                            _FileIDTreeGetFileIDFromPath,
                            _FileIDTreeGetVRefNumFromDeviceID,
                            _FileIDTreePrintVolumeIDs,
                            _FileIDTreePrintVolumeInfo,
                            _FileIDTreePrintVolumeTree, _FileIDTreePrintVolumes,
                            _FileIDTreeServerInit, _GetMacOSStatusCommentString,
                            _GetMacOSStatusErrorCodes,
                            _GetMacOSStatusErrorString, _InvokeVNUPP,
                            _ModeToFSNodeType, _NewVNUPP,
                            _RequestVolumeNotification,
                            _RequestVolumeNotificationWithFlags,
                            _UCCompareTextNoLocale, __CoreServicesServerMain,
                            __FSAddVolumeObserver, __FSAddVolumeObserverOnQueue,
                            __FSGetDisableNetworkVolumes, __FSGetVolumeEncoding,
                            __FSGetVolumeMountpoint, __FSRemoveVolumeObserver,
                            __FSRemoveVolumeObserverOnQueue,
                            __FSScheduleFileVolumeOperations,
                            __FSUnscheduleFileVolumeOperations,
                            __FileIDTreeGetSKServiceDescription,
                            __GDBUserBreakCallbackFunc,
                            __GDBUserBreakShouldSignalWithSIGINT,
                            __GetIOKitDeviceTypeFromDeviceID,
                            __SCGetServerRunLoop,
                            __SCSeedGetSKServiceDescription, _gSCKnownSKPlugins,
                            _kFSEventVolumeAboutToRename,
                            _kFSEventVolumeAboutToUnmount,
                            _kFSEventVolumeMounted,
                            _kFSEventVolumePropertyChanged,
                            _kFSEventVolumeRenamed, _kFSEventVolumeRepairStarted,
                            _kFSEventVolumeUnmountFailed,
                            _kFSEventVolumeUnmounted,
                            _scCreateSystemServiceVersion, _scGetProcessOptions,
                            _scGetServerCheckinPort, _scGetServerOptions,
                            _scRunningInCacheServer ]
...
