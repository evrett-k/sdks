--- !tapi-tbd-v3
archs:                 [ armv7, armv7s, arm64, arm64e ]
platform:              ios
flags:                 [ flat_namespace ]
install-name:          /System/Library/AccessibilityBundles/MobileSafariUI.axbundle/MobileSafariUI
current-version:       0
compatibility-version: 0
objc-constraint:       retain_release
exports:
  - archs:                [ armv7, armv7s, arm64, arm64e ]
    symbols:              [ _accessibilityLocalizedString,
                            _accessibilityMobileSafariLocalizedString,
                            _accessibilitySafariScribbleLocalizedString,
                            _accessibilitySafariServicesLocalizedString,
                            _accessibilitySafariTabClusterLocalizedString,
                            _profileSymbolAccessibilityLabel ]
    objc-classes:         [ AXMobileSafariUIGlue,
                            AddedBookmarkToastViewControllerAccessibility,
                            BookmarksBarLabelButtonAccessibility,
                            BookmarksBarViewAccessibility,
                            BookmarksNavigationControllerAccessibility,
                            BookmarksTableViewControllerAccessibility,
                            BookmarksViewControllerAccessibility,
                            BrowserControllerAccessibility,
                            BrowserRootViewControllerAccessibility,
                            BrowserToolbarAccessibility,
                            CapsuleNavigationBarRegistrationAccessibility,
                            CatalogViewControllerAccessibility,
                            CompletionArrowViewAccessibility,
                            ContinuousReadingViewControllerAccessibility,
                            DownloadTableViewCellAccessibility,
                            LibraryCollectionViewCellAccessibility,
                            MobileSafariUIViewAccessibility,
                            MobileSafariWindowAccessibility,
                            ReadingListTableViewCellAccessibility,
                            ReadingListViewControllerAccessibility,
                            RecentSearchesTableHeaderViewAccessibility,
                            SafariUIApplicationAccessibility,
                            SafariUIDimmingViewAccessibility,
                            SafariUIPageControlAccessibility,
                            SidebarContentDimmingViewAccessibility,
                            StartPageSegmentedViewControllerAccessibility,
                            TabCollectionViewManagerAccessibility,
                            TabControllerAccessibility, TabDocumentAccessibility,
                            TabDocumentViewAccessibility,
                            TabGroupCollectionViewCellAccessibility,
                            UIWebBrowserFindOnPageHighlighterAccessibility,
                            UnifiedFieldAccessibility,
                            UnifiedTabBarAccessibility,
                            __AddedBookmarkToastViewControllerAccessibility_super,
                            __BookmarksBarLabelButtonAccessibility_super,
                            __BookmarksBarViewAccessibility_super,
                            __BookmarksNavigationControllerAccessibility_super,
                            __BookmarksTableViewControllerAccessibility_super,
                            __BookmarksViewControllerAccessibility_super,
                            __BrowserControllerAccessibility_super,
                            __BrowserRootViewControllerAccessibility_super,
                            __BrowserToolbarAccessibility_super,
                            __CapsuleNavigationBarRegistrationAccessibility_super,
                            __CatalogViewControllerAccessibility_super,
                            __CompletionArrowViewAccessibility_super,
                            __ContinuousReadingViewControllerAccessibility_super,
                            __DownloadTableViewCellAccessibility_super,
                            __LibraryCollectionViewCellAccessibility_super,
                            __MobileSafariUIViewAccessibility_super,
                            __MobileSafariWindowAccessibility_super,
                            __ReadingListTableViewCellAccessibility_super,
                            __ReadingListViewControllerAccessibility_super,
                            __RecentSearchesTableHeaderViewAccessibility_super,
                            __SafariUIApplicationAccessibility_super,
                            __SafariUIDimmingViewAccessibility_super,
                            __SafariUIPageControlAccessibility_super,
                            __SidebarContentDimmingViewAccessibility_super,
                            __StartPageSegmentedViewControllerAccessibility_super,
                            __TabCollectionViewManagerAccessibility_super,
                            __TabControllerAccessibility_super,
                            __TabDocumentAccessibility_super,
                            __TabDocumentViewAccessibility_super,
                            __TabGroupCollectionViewCellAccessibility_super,
                            __UIKitAccessibility,
                            __UIWebBrowserFindOnPageHighlighterAccessibility_super,
                            __UnifiedFieldAccessibility_super,
                            __UnifiedTabBarAccessibility_super ]
    objc-ivars:           [ __UIKitAccessibility.__CGRect__ ]
