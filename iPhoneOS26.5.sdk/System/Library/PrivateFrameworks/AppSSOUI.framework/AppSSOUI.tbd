--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AppSSOUI.framework/AppSSOUI
current-version:       483.120.4
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    objc-classes:         [ SOUIAuthorizationViewController ]
    objc-ivars:           [ SOUIAuthorizationViewController._delegate,
                            SOUIAuthorizationViewController._dismissCompletionHandler,
                            SOUIAuthorizationViewController._extensionViewController,
                            SOUIAuthorizationViewController._presentViewControllerCompletionBlock,
                            SOUIAuthorizationViewController._presentViewControllerTimer ]
...
