                            _TtC18CosmeticAssessment33AperturedCameraSessionOverlayView,
                            _TtC18CosmeticAssessment33CosmeticDiagnosticsViewController,
                            _TtC18CosmeticAssessment33SystemCrossfadeTransitionAnimator,
                            _TtC18CosmeticAssessment40CosmeticDiagnosticsOverlayViewController,
                            _TtC18CosmeticAssessment40SessionInitializingLoadingViewController,
                            _TtCC18CosmeticAssessment24DiagnosticsCameraSession20PhotoCaptureDelegate,
                            _TtCC18CosmeticAssessment24DiagnosticsCameraSession23VideoDataOutputDelegate,
                            _TtCC18CosmeticAssessment33CosmeticDiagnosticsViewController16VideoPreviewView ]
