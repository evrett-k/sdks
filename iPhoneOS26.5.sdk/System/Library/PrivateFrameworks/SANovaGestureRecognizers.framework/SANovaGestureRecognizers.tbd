--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SANovaGestureRecognizers.framework/SANovaGestureRecognizers
current-version:       1
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    objc-classes:         [ SANDoubleHalfPressRecognizer, SANForceStageEvent,
                            SANTouchSensitiveButtonEvent ]
    objc-ivars:           [ SANDoubleHalfPressRecognizer._double_half_press_recognizer,
                            SANForceStageEvent._forceProgress,
                            SANForceStageEvent._forceStage,
                            SANForceStageEvent._forceStageTransition,
                            SANForceStageEvent._nextThreshold,
                            SANForceStageEvent._phase,
                            SANForceStageEvent._pressedThreshold,
                            SANForceStageEvent._releasedThreshold,
                            SANForceStageEvent._timestamp,
                            SANTouchSensitiveButtonEvent._eventMask,
                            SANTouchSensitiveButtonEvent._isTouching,
                            SANTouchSensitiveButtonEvent._liftoffVelocity,
                            SANTouchSensitiveButtonEvent._majorRadius,
                            SANTouchSensitiveButtonEvent._phase,
                            SANTouchSensitiveButtonEvent._positionDeltaY,
                            SANTouchSensitiveButtonEvent._positionY,
                            SANTouchSensitiveButtonEvent._timestamp ]
...
