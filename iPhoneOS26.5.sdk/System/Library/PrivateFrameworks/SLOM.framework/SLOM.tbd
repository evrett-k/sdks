--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SLOM.framework/SLOM
current-version:       1.19
compatibility-version: 1.19
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:              [ _SLOMAttitudeStateOutputCreate,
                            _SLOMAttitudeStateOutputGetRotation,
                            _SLOMAttitudeStateOutputGetTimestamp,
                            _SLOMAttitudeStateOutputIsValid,
                            _SLOMAttitudeStateOutputRelease,
                            _SLOMAttitudeStateOutputRetain,
                            _SLOMCalibrationCreate, _SLOMCalibrationRelease,
                            _SLOMCalibrationRetain, _SLOMConfigCreate,
                            _SLOMConfigRelease, _SLOMConfigRetain, _SLOMGetVersion,
                            _SLOMRefinedOutputCreate,
                            _SLOMRefinedOutputGetPositionXY,
                            _SLOMRefinedOutputGetPositionYaw,
                            _SLOMRefinedOutputGetPositionZ,
                            _SLOMRefinedOutputGetRotation,
                            _SLOMRefinedOutputGetTimestamp,
                            _SLOMRefinedOutputIsPoseValid,
                            _SLOMRefinedOutputRelease, _SLOMRefinedOutputRetain,
                            _SLOMSessionCopyLatestAttitudeStateOutput,
                            _SLOMSessionCopyLatestRefinedOutput,
                            _SLOMSessionCopyLatestStitchedOutput,
                            _SLOMSessionCreate, _SLOMSessionPushAcceleration,
                            _SLOMSessionPushGyroscope,
                            _SLOMSessionPushIMUCalibrationAccelerometerBias,
                            _SLOMSessionPushIMUCalibrationGyroscopeBias,
                            _SLOMSessionPushIMUCalibrationGyroscopeScale,
                            _SLOMSessionRelease, _SLOMSessionRetain,
                            _SLOMStitchedOutputCreate,
                            _SLOMStitchedOutputGetPositionXY,
                            _SLOMStitchedOutputGetPositionYaw,
                            _SLOMStitchedOutputGetPositionZ,
                            _SLOMStitchedOutputGetRotation,
                            _SLOMStitchedOutputGetTimestamp,
                            _SLOMStitchedOutputIsPoseValid,
                            _SLOMStitchedOutputRelease,
                            _SLOMStitchedOutputRetain ]
...
