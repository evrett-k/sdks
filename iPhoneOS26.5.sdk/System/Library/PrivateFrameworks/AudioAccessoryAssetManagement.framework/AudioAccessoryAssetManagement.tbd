--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/AudioAccessoryAssetManagement.framework/AudioAccessoryAssetManagement
current-version:       1
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    objc-classes:         [ AMTranslationAssetInfo,
                            AudioAccessoryAssetManagementClient ]
    objc-ivars:           [ AMTranslationAssetInfo._assetStatus,
                            AMTranslationAssetInfo._displayName,
                            AMTranslationAssetInfo._isSuggested,
                            AMTranslationAssetInfo._locale,
                            AudioAccessoryAssetManagementClient._dispatchQueue,
                            AudioAccessoryAssetManagementClient._downloadTranslationAssetsPid,
                            AudioAccessoryAssetManagementClient._interruptionHandler,
                            AudioAccessoryAssetManagementClient._invalidateCalled,
                            AudioAccessoryAssetManagementClient._invalidateDone,
                            AudioAccessoryAssetManagementClient._invalidationHandler,
                            AudioAccessoryAssetManagementClient._processAssertion,
                            AudioAccessoryAssetManagementClient._translationAssets,
                            AudioAccessoryAssetManagementClient._translationAssetsInfoHandler,
                            AudioAccessoryAssetManagementClient._xpcAADCnx,
                            AudioAccessoryAssetManagementClient._xpcCnx ]
...
