--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/HealthDaemonFeatures.framework/HealthDaemonFeatures
current-version:       1
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:              [ _HDMinorExperiencesPluginIdentifier ]
    objc-classes:         [ HDExampleFeatureProfileExtension,
                            HDGlucoseExperienceProfileExtension,
                            HDMinorExperiencesPlugin,
                            HDMinorExperiencesProfileExtension,
                            HDRespiratoryRateMeasurementsProfileExtension,
                            HDWristTemperatureMeasurementsProfileExtension,
                            _TtC20HealthDaemonFeatures26HealthDaemonFeaturesPlugin,
                            _TtC20HealthDaemonFeatures32FeatureAlgorithmVersionsObserver,
                            _TtC20HealthDaemonFeatures35FeatureAlgorithmVersionsSyncManager,
                            _TtC20HealthDaemonFeatures36HealthDaemonFeaturesProfileExtension ]
    objc-ivars:           [ HDExampleFeatureProfileExtension._featureAvailabilityManager,
                            HDExampleFeatureProfileExtension._featureIdentifier,
                            HDExampleFeatureProfileExtension._notificationSyncClient,
                            HDExampleFeatureProfileExtension._profile,
                            HDExampleFeatureProfileExtension._queue,
                            HDGlucoseExperienceProfileExtension._featureAvailabilityManager,
                            HDGlucoseExperienceProfileExtension._featureDeliveryManager,
                            HDGlucoseExperienceProfileExtension._featureIdentifier,
                            HDMinorExperiencesProfileExtension._minorExperiences,
                            HDRespiratoryRateMeasurementsProfileExtension._featureAvailabilityManager,
                            HDRespiratoryRateMeasurementsProfileExtension._featureDeliveryManager,
                            HDRespiratoryRateMeasurementsProfileExtension._featureIdentifier,
                            HDWristTemperatureMeasurementsProfileExtension._featureAvailabilityManager,
                            HDWristTemperatureMeasurementsProfileExtension._featureDeliveryManager,
                            HDWristTemperatureMeasurementsProfileExtension._featureIdentifier ]
...
