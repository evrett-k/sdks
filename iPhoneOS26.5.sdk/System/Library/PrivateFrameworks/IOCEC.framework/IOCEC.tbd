--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/IOCEC.framework/IOCEC
current-version:       1
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:              [ _IOCECFrameStringWithFrame,
                            _IOCECInterfaceCloseReceiveQueue,
                            _IOCECInterfaceCopyProperty, _IOCECInterfaceCreate,
                            _IOCECInterfaceCreateWithService,
                            _IOCECInterfaceGetCECSnoopingEnabled,
                            _IOCECInterfaceGetTypeID,
                            _IOCECInterfaceListenerCreate,
                            _IOCECInterfaceListenerGetTypeID,
                            _IOCECInterfaceListenerRegisterAddInterfaceCallback,
                            _IOCECInterfaceListenerScheduleWithDispatchQueue,
                            _IOCECInterfaceListenerUnscheduleFromDispatchQueue,
                            _IOCECInterfaceOpenReceiveQueue,
                            _IOCECInterfaceRegisterReceiveCallback,
                            _IOCECInterfaceRegisterStatusCallback,
                            _IOCECInterfaceRegisterTerminatedCallback,
                            _IOCECInterfaceScheduleWithDispatchQueue,
                            _IOCECInterfaceSendFrame,
                            _IOCECInterfaceSetLogicalAddressMask,
                            _IOCECInterfaceUnscheduleFromDispatchQueue,
                            _IOCECPhysicalAddressStringWithAddress ]
...
