    symbols:              [ _VoiceControlVersionNumber,
                            _VoiceControlVersionString ]
    objc-classes:         [ VCCommon, VCFeatureFlags, VCLocaleFeatureFlags, VCLog,
                            VCSettingsObjC, VCSignposts,
                            _TtC12VoiceControl10VCSettings,
                            _TtC12VoiceControl14VCNotification ]
...
