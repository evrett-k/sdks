--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/TVAppServices.framework/TVAppServices
current-version:       1
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:              [ _TVAppServicesVersionNumber,
                            _TVAppServicesVersionString ]
    objc-classes:         [ IntentDonationServiceObjC,
                            IntentPlayEventReporterObjC,
                            SportsFavoriteServiceObjC, TVASURLSessionManagerObjC,
                            TVAppAccountStoreObjC, TVAppBag,
                            _TtC13TVAppServices12NetworkProxy,
                            _TtC13TVAppServices12TVAppBagMock,
                            _TtC13TVAppServices13PunchoutEvent,
                            _TtC13TVAppServices14AccountMonitor,
                            _TtC13TVAppServices15ChannelMetadata,
                            _TtC13TVAppServices15LocationManager,
                            _TtC13TVAppServices20UNNotificationClient ]
...
