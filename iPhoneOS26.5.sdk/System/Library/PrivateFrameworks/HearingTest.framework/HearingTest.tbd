--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/HearingTest.framework/HearingTest
current-version:       1
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:              [ _HearingTestVersionNumber, _HearingTestVersionString ]
    objc-classes:         [ _TtC11HearingTest12HTAudiometry,
                            _TtC11HearingTest13HTNoiseOutput,
                            _TtC11HearingTest13Interpolators,
                            _TtC11HearingTest15HTAudioSequence,
                            _TtC11HearingTest15HTNoiseAnalyzer,
                            _TtC11HearingTest17HTCompletionAudio,
                            _TtC11HearingTest19HTAudioSequenceFile,
                            _TtC11HearingTest19HTAudioSequenceTone,
                            _TtC11HearingTest22HTAccessoryAHPSManager,
                            _TtC11HearingTest22SystemVolumeMaintainer,
                            _TtC11HearingTest23AVSessionCategoryVolume,
                            _TtC11HearingTest23HTNSNotificationManager,
                            _TtC11HearingTest24AVSystemControllerHelper,
                            _TtC11HearingTest30HTAudioRouteRequirementManager ]
...
