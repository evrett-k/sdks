                            GPGameLibrary._gameLibraryChangedHandler,
                            GPGameLibrary._invalidated,
                            GPGameLibrary._libraryInitialized,
                            GPGameLibrary._lock, GPGameLibrary._queue,
                            GPGameLibrary._reconnector,
