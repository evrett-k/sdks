--- !tapi-tbd
tbd-version:           4
targets:               [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
flags:                 [ flat_namespace ]
install-name:          /System/Library/PrivateFrameworks/SentencePieceInternal.framework/SentencePieceInternal
current-version:       57.3
compatibility-version: 1
exports:
  - targets:              [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:              [ _SPSentencePieceProcessorAddsDummyPrefix,
                            _SPSentencePieceProcessorCreate,
                            _SPSentencePieceProcessorCreateDecodedStringFromIDs,
                            _SPSentencePieceProcessorCreateDecodedStringFromPieces,
                            _SPSentencePieceProcessorCreateEncodedIDs,
                            _SPSentencePieceProcessorCreateEncodedPieces,
                            _SPSentencePieceProcessorCreateNormalizedString,
                            _SPSentencePieceProcessorCreatePieceFromId,
                            _SPSentencePieceProcessorCreatePieces,
                            _SPSentencePieceProcessorEnumerateEntriesForPredictiveSearch,
                            _SPSentencePieceProcessorEnumerateEntriesWithCommonPrefix,
                            _SPSentencePieceProcessorGetIdFromPiece,
                            _SPSentencePieceProcessorGetLongestPieceLength,
                            _SPSentencePieceProcessorGetPieceSize,
                            _SPSentencePieceProcessorIsByte,
                            _SPSentencePieceProcessorIsControl,
                            _SPSentencePieceProcessorIsUnknown,
                            _SPSentencePieceProcessorRemovesExtraWhitespaces ]
    objc-classes:         [ SPSentencePieceModel ]
    objc-ivars:           [ SPSentencePieceModel._processor ]
...
