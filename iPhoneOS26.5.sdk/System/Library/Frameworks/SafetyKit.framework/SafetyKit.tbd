--- !tapi-tbd
tbd-version:     4
targets:         [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
install-name:    '/System/Library/Frameworks/SafetyKit.framework/SafetyKit'
current-version: 0
compatibility-version: 0
exports:
  - targets:         [ armv7-ios, armv7s-ios, arm64-ios, arm64e-ios ]
    symbols:         [ _CSKappaConnectionBringupFeedbackAssistantMessage, _CSKappaConnectionCommandKey, 
                       _CSKappaConnectionFeedbackAssistantConsentKey, _CSKappaConnectionFeedbackAssistantConsentResponse, 
                       _CSKappaConnectionFeedbackAssistantUUIDKey, _CSKappaConnectionReturn, 
                       _CSKappaConnectionSendCommandName, _CSKappaConnectionServiceName, 
                       _CSKappaConnectionTestAOIName, _CSKappaConnectionTestMessageName, 
                       _CSKappaConnectionTestPowerAssertionName, _CSKappaConnectionTestSOSName, 
                       _CSKappaConnectionTestSensorAccessQuery, _CSKappaConnectionTestSignalName, 
                       _CSKappaConnectionTestTTRName, _CSKappaConnectionTestTriggerName, 
                       _CSKappaConnectionValueKey, _SAClientInterface, _SACrashDetectionEntitlement, 
                       _SACrashDetectionEventTimeoutDefault, _SAEmergencyResponseVoiceCallTimeoutDefault, 
                       _SAErrorDomain, _SALoggingSubsystem, _SAMachServiceName, _SAServerInterface, 
                       _sa_default_log ]
    objc-classes:    [ CSKappaConnection, SAAuthorization, SAAuthorizationInFlight, 
                       SABundleManager, SABundleManagerApp, SAClient, SACrashDetectionEvent, 
                       SACrashDetectionManager, SACriticalNotification, SAEmergencyResponseManager, 
                       SAEntitlement, SAError, SAGestalt, SALocationManager, SAPhoneApplicationLauncher, 
                       SAServer, SATelephonyManager, SAWatchApplicationLauncher ]
...
