                       CXSetTTYTypeCallAction, CXSetTranslatingCallAction, CXSetTrashedVoicemailAction, 
                       CXSetVideoPresentationSizeCallAction, CXSetVideoPresentationStateCallAction, 
                       CXShareIdentityCallAction, CXStartCallAction, CXTransaction, 
                       CXTransactionGroup, CXTransactionManager, CXVoicemail, CXVoicemailAction, 
                       CXVoicemailController, CXVoicemailControllerHost, CXVoicemailObserver, 
                       CXVoicemailProvider, CXVoicemailSource, CXVoicemailUpdate, 
                       CXXPCChannelProvider, CXXPCProvider, CXXPCVoicemailSource ]
