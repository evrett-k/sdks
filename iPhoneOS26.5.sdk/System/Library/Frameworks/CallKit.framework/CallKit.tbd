    symbols:         [ _CXCallDirectoryDefaultHostBundleIdentifier, _CXCallDirectoryDefaultHostServiceName, 
                       _CXCallDirectoryExtensionPointIdentifier, _CXCallDirectoryMaintenanceHostBundleIdentifier, 
                       _CXCallDirectoryMaintenanceHostServiceName, _CXCallDirectoryManagerIdentificationEntriesChangedNotification, 
